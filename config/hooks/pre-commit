#!/bin/sh

fail=0

blocked_files=$(git diff --cached --name-only --diff-filter=ACM | grep -iE '\.(pfx|p12|key)$' || true)
if [ -n "$blocked_files" ]; then
  echo "[secret-guard] Refusing to commit private-key file(s):"
  echo "$blocked_files" | sed 's/^/    /'
  fail=1
fi

patterns='GOCSPX-|"cscKeyPassword"|-----BEGIN [A-Z ]*PRIVATE KEY-----'
if git diff --cached -U0 -- . ':(exclude)config/hooks/pre-commit' | grep -E '^\+[^+]' | grep -Eq "$patterns"; then
  echo "[secret-guard] Staged changes contain a secret-like pattern."
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo "Commit aborted by config/hooks/pre-commit (bypass: git commit --no-verify)."
  exit 1
fi

exit 0
