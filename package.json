{
  "name": "make-your-life-easier",
  "version": "4.5.5",
  "description": "A modern, user-friendly desktop application with auto-updater",
  "author": "ThomasThanos <thomasthanos2@icloud.com>",
  "homepage": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "cls && electron . --no-updater",
    "build-updater": "cls &&  %SystemRoot%\\Microsoft.NET\\Framework64\\v4.0.30319\\csc.exe /nologo /target:winexe /optimize+ /out:src\\resources\\updater\\Updater.exe /r:System.IO.Compression.FileSystem.dll /r:System.IO.Compression.dll /win32icon:src\\assets\\icons\\hacker.ico tools\\updater\\Updater.cs",
    "build-app": "cls && electron-builder --win portable && electron-builder --win nsis zip && node tools/patch-latest-yml.js",
    "build-all": "cls && npm run build-updater && npm run build-app",
    "lint": "cls && eslint --config config/eslint.config.js .",
    "prepare": "cls && node config/setup-hooks.js",
    "postinstall": "cls && electron-builder install-app-deps"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2"
  },
  "build": {
    "appId": "com.kolokithes.makeyourlifeeasier",
    "productName": "MakeYourLifeEasier",
    "directories": {
      "output": "artifacts/dist"
    },
    "files": [
      "package.json",
      "src/**/*",
      "!src/resources/bin/**/*",
      "!src/public/**/*"
    ],
    "extraResources": [
      {
        "from": "src/resources/bin",
        "to": "bin",
        "filter": [
          "7za.exe",
          "7za.dll",
          "7zxa.dll",
          "certificate.cer"
        ]
      },
      {
        "from": "src/resources/updater",
        "to": "updater",
        "filter": [
          "Updater.exe"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MakeYourLifeEasier-win.${ext}",
      "icon": "src/assets/icons/hacker.ico",
      "signtoolOptions": {
        "certificateSubjectName": "ThomasThanos",
        "publisherName": "ThomasThanos",
        "signingHashAlgorithms": [
          "sha256"
        ]
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Make Your Life Easier",
      "installerIcon": "src/assets/icons/hacker.ico",
      "uninstallerIcon": "src/assets/icons/hacker.ico",
      "warningsAsErrors": false,
      "artifactName": "MakeYourLifeEasier-installer.exe",
      "deleteAppDataOnUninstall": true,
      "include": "config/installer.nsh",
      "guid": "MakeYourLifeEasier",
      "uninstallDisplayName": "Make Your Life Easier ${version}",
      "uninstallUrlHelp": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/public/copyright.html",
      "uninstallUrlInfoAbout": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/renderer/info/info.html",
      "uninstallUrlReadme": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/public/readme.html",
      "uninstallUrlUpdateInfo": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/public/changelog.html",
      "differentialPackage": true,
      "runAfterFinish": true,
      "allowElevation": false
    },
    "portable": {
      "artifactName": "MakeYourLifeEasier-Portable.exe"
    },
    "publish": {
      "provider": "generic",
      "url": "https://pub-55b723f83c32414ea5c259c71e94b605.r2.dev"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasthanos/Make_Your_Life_Easier.A.E.git"
  }
}
