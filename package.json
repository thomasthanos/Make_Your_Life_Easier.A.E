{
  "name": "make-your-life-easier",
  "version": "4.5.9",
  "description": "A modern, user-friendly desktop application with auto-updater",
  "author": "ThomasThanos <thomasthanos2@icloud.com>",
  "homepage": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "cls && electron . --no-updater",
    "build-all": "cls && %SystemRoot%\\Microsoft.NET\\Framework64\\v4.0.30319\\csc.exe /nologo /target:winexe /optimize+ /out:src\\resources\\updater\\Updater.exe /r:System.IO.Compression.FileSystem.dll /r:System.IO.Compression.dll /win32icon:src\\assets\\icons\\hacker.ico tools\\updater\\Updater.cs && electron-builder --win portable zip && node tools/patch-latest-yml.js && electron-builder --config config/electron-builder.setup.json && node tools/clean-dist.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2"
  },
  "build": {
    "appId": "com.kolokithes.makeyourlifeeasier",
    "productName": "MakeYourLifeEasier",
    "directories": {
      "output": "artifacts/dist"
    },
    "files": [
      "package.json",
      "src/**/*",
      "!src/resources/bin/**/*",
      "!src/public/**/*"
    ],
    "extraResources": [
      {
        "from": "src/resources/bin",
        "to": "bin",
        "filter": [
          "7za.exe",
          "7za.dll",
          "7zxa.dll",
          "certificate.cer"
        ]
      },
      {
        "from": "src/resources/updater",
        "to": "updater",
        "filter": [
          "Updater.exe"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MakeYourLifeEasier-win.${ext}",
      "icon": "src/assets/icons/hacker.ico",
      "signtoolOptions": {
        "certificateSubjectName": "ThomasThanos",
        "publisherName": "ThomasThanos",
        "signingHashAlgorithms": [
          "sha256"
        ]
      }
    },
    "portable": {
      "artifactName": "MakeYourLifeEasier-Portable.exe"
    },
    "publish": {
      "provider": "generic",
      "url": "https://pub-55b723f83c32414ea5c259c71e94b605.r2.dev"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasthanos/Make_Your_Life_Easier.A.E.git"
  }
}
