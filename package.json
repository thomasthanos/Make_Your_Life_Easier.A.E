{
  "name": "make-your-life-easier",
  "version": "4.0.2",
  "description": "A modern, user-friendly desktop application with auto-updater",
  "author": "ThomasThanos <thomasthanos2@icloud.com>",
  "homepage": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "cls && electron . --no-updater",
    "build-all": "cls && electron-builder --win portable && electron-builder --win nsis",
    "release": "cls && electron-builder --win portable && electron-builder --win nsis && electron-builder --publish=always",
    "lint": "eslint --config config/eslint.config.js .",
    "lint:fix": "eslint --config config/eslint.config.js . --fix",
    "format": "prettier --config config/prettier.config.json --ignore-path config/prettier.ignore --write .",
    "format:check": "prettier --config config/prettier.config.json --ignore-path config/prettier.ignore --check .",
    "prepare": "node config/setup-hooks.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-sudo": "^4.0.12",
    "electron-updater": "^6.8.9",
    "node-windows": "^1.0.0-beta.8",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2"
  },
  "build": {
    "appId": "com.kolokithes.makeyourlifeeasier",
    "productName": "MakeYourLifeEasier",
    "directories": {
      "output": "artifacts/dist"
    },
    "files": [
      "package.json",
      "src/**/*",
      "!src/resources/bin/**/*",
      "!src/config/oauth_config.json",
      "!src/public/**/*"
    ],
    "extraResources": [
      {
        "from": "src/resources/bin",
        "to": "bin",
        "filter": [
          "7za.exe",
          "7za.dll",
          "7zxa.dll",
          "certificate.cer"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icons/hacker.ico",
      "signtoolOptions": {
        "publisherName": "ThomasThanos",
        "signingHashAlgorithms": [
          "sha256"
        ]
      },
      "publish": {
        "provider": "github",
        "releaseType": "release"
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Make Your Life Easier",
      "installerIcon": "src/assets/icons/hacker.ico",
      "uninstallerIcon": "src/assets/icons/hacker.ico",
      "warningsAsErrors": false,
      "artifactName": "MakeYourLifeEasier-installer.exe",
      "deleteAppDataOnUninstall": true,
      "include": "config/installer.nsh",
      "guid": "MakeYourLifeEasier",
      "uninstallDisplayName": "Make Your Life Easier ${version}",
      "uninstallUrlHelp": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/public/copyright.html",
      "uninstallUrlInfoAbout": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/renderer/info/info.html",
      "uninstallUrlReadme": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/public/readme.html",
      "uninstallUrlUpdateInfo": "https://thomasthanos.github.io/Make_Your_Life_Easier.A.E/src/public/changelog.html",
      "differentialPackage": true,
      "runAfterFinish": true,
      "allowElevation": false
    },
    "portable": {
      "artifactName": "MakeYourLifeEasier-Portable.exe"
    },
    "generateUpdatesFilesForAllChannels": true,
    "publish": {
      "provider": "github",
      "owner": "thomasthanos",
      "repo": "Make_Your_Life_Easier.A.E",
      "private": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasthanos/Make_Your_Life_Easier.A.E.git"
  }
}
